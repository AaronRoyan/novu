# Valhalla container version and host port.
VALHALLA_VERSION=3.7.0
VALHALLA_PORT=8002
VALHALLA_THREADS=2

# Small, fast default. Replace with the Geofabrik extract covering your users.
# Examples:
#   Great Britain: https://download.geofabrik.de/europe/great-britain-latest.osm.pbf
#   England:       https://download.geofabrik.de/europe/great-britain/england-latest.osm.pbf
OSM_PBF_URL=https://download.geofabrik.de/europe/andorra-latest.osm.pbf

# These affect the next tile build. Large extracts need substantial RAM/disk.
VALHALLA_FORCE_REBUILD=False
VALHALLA_BUILD_ADMINS=True
VALHALLA_BUILD_TIME_ZONES=True
VALHALLA_BUILD_ELEVATION=False

# URL used by the Expo application. A physical device must use your computer's
# LAN IP instead of localhost, for example http://192.168.1.20:8002.
EXPO_PUBLIC_VALHALLA_URL=http://localhost:8002

